generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// User Role for Authorization Process
enum Role {
  USER
  ADMIN
}


model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?
  email         String?   @unique
  password      String?
  emailVerified DateTime? @map("email_verified")
  image         String?
  accounts      Account[]
  role          Role  @default(USER)
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}


model VerificationToken{
  id      String  @id @default(cuid())
  email   String
  token   String  @unique
  expire  DateTime

  @@unique([email,token]) // avoid store [ email and token ] to multi user with the same data
}

model ForgetPasswordToken{
  id      String  @id @default(cuid())
  email   String
  token   String  @unique
  expire  DateTime

  @@unique([email,token])
}

// - @map in postgres: [ like a middleware that receive think then processed | convert it into anther think to be worked successfully with next part ! ]

