generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int     @id @default(autoincrement())
  username  String
  email     String  @unique
  followers Int     @default(1)
  IsActive  Boolean @default(true)
  RegisterAt DateTime @default(now())
}
